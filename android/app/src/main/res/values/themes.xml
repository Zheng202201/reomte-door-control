<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RemoteDoorControl" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/bg_card</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <style name="CompactControlButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/control_btn_height</item>
        <item name="android:textSize">@dimen/control_btn_text</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingLeft">6dp</item>
        <item name="android:paddingRight">6dp</item>
    </style>

    <style name="SectionLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="LoginTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="hintTextColor">@color/login_hint</item>
        <item name="boxStrokeColor">@color/login_input_stroke</item>
    </style>

    <style name="LoginEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/login_hint</item>
    </style>
</resources>
